<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="200dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView android:id="@+id/title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textStyle="bold"
            android:textSize="14sp"/>

        <ImageButton android:id="@+id/btn_favori"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@null"
            android:paddingEnd="4dp"/>

        <TextView android:id="@+id/close_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✕"
            android:textSize="16sp"
            android:textColor="#888888"
            android:paddingStart="8dp"/>

    </LinearLayout>

    <TextView android:id="@+id/places"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🅿️ Places libres : -"/>

    <TextView android:id="@+id/velos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🚲 Vélos dispo : -"/>

    <TextView android:id="@+id/capacite"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📦 Capacité : -"/>

</LinearLayout>